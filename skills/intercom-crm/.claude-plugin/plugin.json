{
  "name": "intercom-crm",
  "displayName": "Intercom",
  "version": "1.0.0",
  "description": "Manage customer messaging and support with conversational platform",
  "author": "Canifi",
  "repository": "https://github.com/canifi/life-os-skills",
  "category": "business-crm",
  "keywords": ["messaging", "chat", "support", "intercom", "conversations"],
  "capabilities": [
    "conversation_management",
    "user_management",
    "automated_messages",
    "help_center",
    "product_tours"
  ],
  "authentication": {
    "type": "bearer",
    "provider": "intercom",
    "headerName": "Authorization",
    "headerPrefix": "Bearer"
  },
  "endpoints": {
    "baseUrl": "https://api.intercom.io",
    "conversations": "/conversations",
    "contacts": "/contacts",
    "messages": "/messages",
    "articles": "/articles"
  },
  "rateLimit": {
    "requests": 1000,
    "period": "minute"
  },
  "environmentVariables": [
    {
      "name": "INTERCOM_ACCESS_TOKEN",
      "description": "Intercom API access token",
      "required": true
    },
    {
      "name": "INTERCOM_APP_ID",
      "description": "Intercom app ID",
      "required": false
    }
  ],
  "dependencies": [],
  "platforms": ["web", "ios", "android"],
  "documentationUrl": "https://developers.intercom.com/"
}
